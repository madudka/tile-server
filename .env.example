# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# Database username (must match POSTGRES_USER in postgres service)
POSTGRES_USER=renderer

# Path to password file (mounted as Docker secret)
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

# Database name for OSM data
POSTGRES_DB=gis


# ============================================================================
# Database Connection
# Used by importer, renderd, and mapnik-xml-generator
# ============================================================================

# PostgreSQL service hostname (docker-compose service name)
POSTGRES_HOST=postgres

# PostgreSQL port
POSTGRES_PORT=5432


# ============================================================================
# Importer Configuration
# ============================================================================

# Import mode for osm2pgsql
#   auto    - Auto-detect: create if no tables exist, append otherwise
#   create  - Fresh import (drops existing tables)
#   append  - Incremental update (adds to existing data)
IMPORT_MODE=auto

# RAM (MB) for osm2pgsql node caching in --slim mode
# Higher cache = faster import (reduces disk I/O)
# Recommendation: Use the SMALLER of:
#   - Size of your .pbf file
#   - 75% of available system RAM
# Default: 2048 MB
OSM2PGSQL_CACHE=2048

# Number of parallel processing threads for osm2pgsql
# More threads = faster processing (up to a point)
# Recommendation: CPU cores, but capped at 4
#   - Values >4 rarely improve performance
#   - Default works well for most systems
# Default: 4
OSM2PGSQL_THREADS=4


# ============================================================================
# Renderd Configuration
# ============================================================================

# Enable placeholder replacement in mapnik.xml
#   true   - Replace {{DB_HOST}}, {{DB_PORT}}, etc. with actual values
#   false  - Use pre-configured mapnik.xml without modification
USE_PLACEHOLDERS=true

# Import external geospatial data (coastlines, boundaries, water polygons)
#   true   - Download and import external data on startup
#   false  - Skip external data import (use cached data)
IMPORT_EXTERNAL_DATA=true